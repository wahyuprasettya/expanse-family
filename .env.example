# Firebase & API Keys – copy this file to .env and fill in your values
# Then update src/services/firebase/config.js with these values

FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID
FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Google Cloud Vision API (for OCR receipt scanning)
GOOGLE_CLOUD_VISION_API_KEY=YOUR_GOOGLE_CLOUD_VISION_KEY

# Expo Project ID (from expo.dev)
EXPO_PROJECT_ID=YOUR_EXPO_PROJECT_ID
